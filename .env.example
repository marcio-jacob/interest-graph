NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
OLLAMA_MODEL=llama3.2

# Neo4j Aura API credentials for GDS Sessions (serverless graph analytics)
# Create at: https://console.neo4j.io → API Keys
AURA_CLIENT_ID=your_aura_client_id
AURA_CLIENT_SECRET=your_aura_client_secret
